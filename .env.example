# Image Upscaler - Environment Configuration

# Database
DATABASE_URL=sqlite:///./image_morph.db

# Redis (for Celery queue processing)
REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 (Optional - for cloud storage)
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=image-upscaler
R2_PUBLIC_URL=

# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
MAX_FILE_SIZE=52428800
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Upscaler Settings
UPSCALE_MAX_DIMENSION=4096
MODELS_DIR=./models
RESULTS_DIR=./results
UPLOADS_DIR=./uploads
CLEANUP_HOURS=24

# Celery Settings
CELERY_WORKERS=2
CELERY_TASK_TIMEOUT=3600
